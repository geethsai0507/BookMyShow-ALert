{
  "manifest_version": 3,
  "name": "ShowAlert – BMS Ticket Notifier",
  "short_name": "ShowAlert",
  "version": "1.1.0",
  "description": "Get instant email alerts when BookMyShow tickets open for your chosen theatre and date.",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://in.bookmyshow.com/*",
    "https://api.resend.com/*",
    "https://api.brevo.com/*",
    "https://api.mailjet.com/*",
    "https://api.mailersend.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://in.bookmyshow.com/cinemas/*/*/buytickets/*/*"],
      "js": ["page_extractor.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://in.bookmyshow.com/cinemas/*/*/buytickets/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ShowAlert – BMS Notifier",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://in.bookmyshow.com/*"]
    }
  ]
}
